# Discord bot token (required) — from https://discord.com/developers/applications
DISCORD_TOKEN=

# Discord application (client) ID — used for registering slash commands
DISCORD_APP_ID=1492686913025605642

# Discord guild (server) ID — slash commands register here for instant updates
DISCORD_GUILD_ID=936268439465623563

# Command prefix (default: !claude)
PREFIX=!claude

# Comma-separated list of Discord channel IDs the bot responds in (leave empty to allow all)
ALLOWED_CHANNELS=

# Comma-separated list of Discord user IDs allowed to use the bot (leave empty to allow all)
ALLOWED_USERS=

# Max concurrent Claude processes (default: 3)
MAX_CONCURRENT=3

# Claude command timeout in milliseconds (default: 300000 = 5 minutes)
CLAUDE_TIMEOUT=300000

# Max output buffer size in bytes (default: 1048576 = 1MB)
MAX_BUFFER=1048576

# --- Insights-UI (KoalaGains) channel routing ---

# Discord channel ID that triggers the insights-ui worktree workflow
INSIGHTS_UI_CHANNEL=1491102767224324309

# Path to the main dodao-ui repo (READ-ONLY, stays on main)
INSIGHTS_UI_MAIN_REPO=/home/ubuntu/.openclaw/workspace-insights-ui/dodao-ui

# Path to the worktree base directory
INSIGHTS_UI_WORKTREE_BASE=/home/ubuntu/.openclaw/workspace-insights-ui/worktrees

# --- Outreach-Data channel routing ---

# Discord channel ID that triggers the outreach-data workflow
OUTREACH_DATA_CHANNEL=1491111325173022933

# Path to the outreach-data workspace
OUTREACH_DATA_WORKSPACE=/home/ubuntu/.openclaw/workspace-outreach-data

# --- Gmail (Ambassador Email Workflows) channel routing ---

# Discord channel ID that triggers the Gmail workflow handler
GMAIL_CHANNEL=1491111325173022934

# Path to the Gmail workspace
GMAIL_WORKSPACE=/home/ubuntu/.openclaw/workspace-gmail
